ARG PRODUCT_REGISTRY=harbor.delivery.iqgeo.cloud
ARG PRODUCT_REPOSITORY_PREFIX=releases_
ARG PROJECT_REGISTRY=harbor.delivery.iqgeo.cloud
ARG PROJECT_REPOSITORY=sandbox
ARG BUILD_IMAGE=${PROJECT_REGISTRY}/${PROJECT_REPOSITORY}/iqgeo-sandbox-build

FROM ${BUILD_IMAGE} AS iqgeo_builder

# START SECTION optional dependencies (build) - if you edit these lines manually note that your change will get lost if you run the IQGeo Project Update tool

# END SECTION

RUN myw_product fetch pip_packages --include redis oidc

# remove unneeded files for appserver
RUN rm -rf ${MODULES}/*/node_modules \
    && rm -rf ${MODULES}/*/package*.json \
    && rm -rf ${MODULES}/*/native

############################################## project appserver image
FROM ${PRODUCT_REGISTRY}/${PRODUCT_REPOSITORY_PREFIX}platform/platform-appserver:7.4

USER root

# START SECTION optional dependencies (runtime) - if you edit these lines manually note that your change will get lost if you run the IQGeo Project Update tool

# END SECTION

# Copy pip packages including modules' pip dependencies
COPY --chown=www-data:www-data --from=iqgeo_builder /opt/iqgeo/platform/Externals/lib/python${PY_VERSION:-3.10}/site-packages /opt/iqgeo/platform/Externals/lib/python${PY_VERSION:-3.10}/site-packages

# START SECTION Copy modules  - if you edit these lines manually note that your change will get lost if you run the IQGeo Project Update tool
COPY --chown=www-data:www-data --from=iqgeo_builder ${MODULES}/custom/ ${MODULES}/custom/
COPY --chown=www-data:www-data --from=iqgeo_builder ${MODULES}/construction_print/ ${MODULES}/construction_print/
COPY --chown=www-data:www-data --from=iqgeo_builder ${MODULES}/workflow_manager/ ${MODULES}/workflow_manager/
COPY --chown=www-data:www-data --from=iqgeo_builder ${MODULES}/groups/ ${MODULES}/groups/
# END SECTION

# START CUSTOM SECTION
# END CUSTOM SECTION


# Copy in generated bundles
COPY --chown=www-data:www-data --from=iqgeo_builder ${WEBAPPS}/myworldapp/public ${WEBAPPS}/myworldapp/public/


USER www-data


# add additional entrypoint scripts (build db, ...)
COPY --chown=www-data:www-data entrypoint.d/* /entrypoint.d/

# Normalize line endings (defensive against CRLF from Windows editors) and ensure executable
USER root
RUN sed -i 's/\r$//' /entrypoint.d/* 2>/dev/null || true \
    && chmod -R a+rx /entrypoint.d/* 2>/dev/null || true
USER www-data


COPY --chown=www-data:www-data appserver_config/ /opt/iqgeo/config/
